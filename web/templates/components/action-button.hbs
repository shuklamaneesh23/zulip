<button {{#if id}}id="{{id}}"{{/if}} class="{{#if custom_classes}}{{custom_classes}} {{/if}}action-button action-button-{{type}}-{{intent}} {{#if hidden}}hide{{/if}}" tabindex="0" {{#if aria-label}}aria-label="{{aria-label}}"{{/if}}
  {{#if disabled}}disabled{{/if}}>
    {{#if icon}}
    <i class="zulip-icon zulip-icon-{{icon}}" aria-hidden="true"></i>
    {{/if}}
    <span class="action-button-label">{{label}}</span>
</button>
