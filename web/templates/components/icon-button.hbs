<button {{#if id}}id="{{id}}"{{/if}} class="{{#if custom_classes}}{{custom_classes}} {{/if}}icon-button icon-button-{{intent}} {{#if hidden}}hide{{/if}}" tabindex="0"
  {{#if aria-label}}aria-label="{{aria-label}}"{{/if}}
  {{#if data-tippy-content}}data-tippy-content="{{data-tippy-content}}"{{/if}}
  >
    <i class="zulip-icon zulip-icon-{{icon}}" aria-hidden="true"></i>
</button>
